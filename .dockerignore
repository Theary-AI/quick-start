# Keep the build context small and never ship local secrets into the image.

# dependencies (reinstalled inside the image from the lockfile)
node_modules
.pnp
.pnp.*
.yarn

# next.js build artifacts
.next
out
build

# local env files — NEVER copy real secrets into the image
.env
.env.local
.env*.local

# version control / editor / OS cruft
.git
.gitignore
.DS_Store
*.pem

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# docs & CI that aren't needed at runtime
README.md
DEPLOY.md
.github

# typescript build info
*.tsbuildinfo
