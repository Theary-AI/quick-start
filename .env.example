# ---------------------------------------------------------------------------
# SNH AI Integration Quickstart - environment configuration
#
# Copy this file to `.env.local` and fill in the values you received from
# SNH AI. `.env.local` is git-ignored and is read only on the server, so your
# credentials are NEVER exposed to the browser.
# ---------------------------------------------------------------------------

# Base URL of the API you are integrating against.
#   sandbox:    https://sandbox.theary.com
#   production: https://api.theary.ai
API_BASE_URL=https://sandbox.theary.com

# --- Authentication -------------------------------------------------------
# The app authenticates with the API using the OAuth client-credentials flow.
# In the common case you only need to set the client id and secret below; the
# token endpoint (AUTH_DOMAIN) and audience (AUTH_AUDIENCE) are derived from
# API_BASE_URL automatically. Request credentials from support@snh-ai.com.
# Do NOT commit these values.
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# Optional overrides. Leave blank to use the defaults for the environment
# implied by API_BASE_URL:
#   sandbox/local: AUTH_DOMAIN=https://auth-dev.theary.ai   AUTH_AUDIENCE=https://empv-auth-dev.theary.ai
#   production:    AUTH_DOMAIN=https://auth.theary.ai        AUTH_AUDIENCE=https://verification-auth.theary.ai
AUTH_DOMAIN=
AUTH_AUDIENCE=

# Optional: a pre-issued Bearer JWT. If set, it OVERRIDES the client-credentials
# flow and is sent as-is. Useful if SNH AI hands you a token that already
# contains the required `tenant` claim. Leave blank to use AUTH_CLIENT_ID/SECRET.
AUTH_TOKEN=

# Shared secret used to sign and verify webhook payloads (HMAC-SHA256).
# Pick any strong random string. The quickstart sends it on the order's
# webhookConfig and verifies the `X-Webhook-Signature` header on inbound
# webhooks. Leave blank to skip signature verification (not recommended).
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Public base URL where the API can reach this app's webhook endpoint.
# Leave blank to let the quickstart auto-detect your running ngrok tunnel
# (via the local ngrok API at http://127.0.0.1:4040). Set it manually if you
# expose the app another way, e.g. https://your-app.com
PUBLIC_BASE_URL=

# --- Public Records (CRA evaluation framework) ----------------------------
# The Public Records product calls a SEPARATE API that synchronously evaluates
# a criminal/court record and returns a compliance routing decision. It has its
# own auth and does NOT accept the verification token: CRA validates HS256
# tokens minted by its own /auth/token endpoint, whereas the verification token
# is an Auth0 RS256 token (presenting it returns 401 "alg value is not allowed").
# Mirror the verification token mechanism, but with CRA credentials:
#   - Set PUBLIC_RECORDS_API_KEY and the app exchanges it for a short-lived JWT
#     at `${PUBLIC_RECORDS_API_BASE_URL}/auth/token` (X-API-Key header).
#   - OR set PUBLIC_RECORDS_TOKEN to a pre-issued CRA Bearer JWT, sent as-is
#     (overrides the key exchange).
#
# Base URL of the evaluation API.
#   staging:    https://cra.pr.stg.snh-ai.com
#   production: https://cra.pr.snh-ai.com
PUBLIC_RECORDS_API_BASE_URL=https://cra.pr.stg.snh-ai.com

# API key exchanged for a JWT at /auth/token. From GCP Secret Manager:
#   gcloud secrets versions access latest --secret=eval-framework-api-key --project=theary-core-prod
PUBLIC_RECORDS_API_KEY=

# Optional pre-issued CRA Bearer JWT. When set it overrides PUBLIC_RECORDS_API_KEY.
PUBLIC_RECORDS_TOKEN=
